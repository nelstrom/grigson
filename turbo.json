{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "_site/**", "src/parser.c", "src/grammar.json", "src/node-types.json"],
      "env": ["ELEVENTY_PATH_PREFIX", "VITE_FONTS", "VITE_BUILD_REGISTER", "VITE_VISUALIZE"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "serve": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    }
  }
}
