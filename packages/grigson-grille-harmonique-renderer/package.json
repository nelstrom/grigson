{
  "name": "grigson-grille-harmonique-renderer",
  "version": "1.0.0",
  "description": "A grille harmonique renderer for grigson-chart",
  "bin": {
    "grigson-grille-harmonique-renderer": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm run build:ts && pnpm run build:browser && pnpm run build:browser:register",
    "build:browser": "vite build",
    "build:browser:register": "VITE_BUILD_REGISTER=true vite build",
    "build:ts": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "grigson": "workspace:*",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
