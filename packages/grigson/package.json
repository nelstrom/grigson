{
  "name": "grigson",
  "version": "1.0.0",
  "description": "A plain-text chord chart format with parser and renderer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "grigson": "./dist/cli.js",
    "grigson-html-renderer": "./dist/html-renderer-cli.js"
  },
  "scripts": {
    "build": "pnpm run build:grammar && pnpm run build:ts && pnpm run build:copy && pnpm run build:browser && pnpm run build:browser:register",
    "build:browser": "vite build",
    "build:browser:register": "VITE_BUILD_REGISTER=true vite build",
    "build:grammar": "peggy --format es --dts --allowed-start-rules Song,FrontMatter,Row,Bar,Chord -o src/parser/generated.js src/parser/grammar.pegjs",
    "build:ts": "tsc",
    "build:copy": "cp src/parser/generated.js dist/parser/generated.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "pnpm run build:grammar",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "prettier --write src/",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "fast-check": "^4.6.0",
    "happy-dom": "^20.8.4",
    "peggy": "^5.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "minimist": "^1.2.8"
  }
}
