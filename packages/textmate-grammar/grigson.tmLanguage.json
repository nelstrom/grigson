{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Grigson",
  "scopeName": "source.grigson",
  "patterns": [
    {
      "include": "#main"
    }
  ],
  "repository": {
    "main": {
      "patterns": [
        {
          "include": "#frontmatter"
        },
        {
          "include": "#section-label"
        },
        {
          "include": "#barline"
        },
        {
          "include": "#chord"
        }
      ]
    },
    "frontmatter": {
      "begin": "^---$",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.header.grigson"
        }
      },
      "end": "^---$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.header.grigson"
        }
      },
      "patterns": [
        {
          "match": "([a-zA-Z]+)(:)\\s*(\".*\")",
          "captures": {
            "1": {
              "name": "variable.parameter.key.grigson"
            },
            "2": {
              "name": "punctuation.separator.key-value.grigson"
            },
            "3": {
              "name": "string.quoted.double.grigson"
            }
          }
        },
        {
          "match": "([a-zA-Z]+)(:)\\s*(.*)",
          "captures": {
            "1": {
              "name": "variable.parameter.key.grigson"
            },
            "2": {
              "name": "punctuation.separator.key-value.grigson"
            },
            "3": {
              "name": "string.unquoted.grigson"
            }
          }
        }
      ]
    },
    "section-label": {
      "match": "^(\\[)([^\\]\\r\\n]+)(\\])\\s*$",
      "captures": {
        "1": {
          "name": "punctuation.definition.section.begin.grigson"
        },
        "2": {
          "name": "entity.name.section.grigson"
        },
        "3": {
          "name": "punctuation.definition.section.end.grigson"
        }
      }
    },
    "barline": {
      "match": "\\|",
      "name": "punctuation.definition.barline.grigson"
    },
    "chord": {
      "match": "(?<=^|\\s|\\|)([A-G])([#b])?(m7b5|m|7)?(?=\\s|\\||$)",
      "captures": {
        "1": {
          "name": "constant.other.chord.root.grigson"
        },
        "2": {
          "name": "constant.other.chord.accidental.grigson"
        },
        "3": {
          "name": "keyword.other.chord.quality.grigson"
        }
      }
    }
  }
}
