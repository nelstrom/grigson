---
layout: base.njk
---
{{ content | safe }}

<grigson-chart normalise>
  <template>{{ chartName | readChart }}</template>
</grigson-chart>

{% set songs = collections.songbook | sort(false, false, 'data.order') %}
{% set currentIndex = songs | indexOf(page) %}
<nav class="songbook-nav">
  <a href="/songbook/">Songbook</a>
  <span class="songbook-nav-arrows">
    {% if currentIndex > 0 %}
      <a href="{{ songs[currentIndex - 1].url }}">← {{ songs[currentIndex - 1].data.title }}</a>
    {% endif %}
    {% if currentIndex < songs.length - 1 %}
      <a href="{{ songs[currentIndex + 1].url }}">{{ songs[currentIndex + 1].data.title }} →</a>
    {% endif %}
  </span>
</nav>
