---
layout: base.njk
---
{{ content | safe }}

{% if chartName %}
<h2>Source</h2>
{{ chartName | highlightChart | safe }}

<h2>Normalised output</h2>
<grigson-chart normalise>
  <template>{{ chartName | readChart }}</template>
</grigson-chart>
{% endif %}

{% if tags and 'language-syntax' in tags %}
  {% set lessons = collections['language-syntax'] | sort(false, false, 'data.order') %}
{% else %}
  {% set lessons = collections.tutorial | sort(false, false, 'data.order') %}
{% endif %}
{% set currentIndex = lessons | indexOf(page) %}
<nav class="lesson-nav">
  {% if currentIndex > 0 %}
    <a href="{{ lessons[currentIndex - 1].url | url }}">← Previous</a>
  {% endif %}
  {% if currentIndex < lessons.length - 1 %}
    <a href="{{ lessons[currentIndex + 1].url | url }}">Next →</a>
  {% endif %}
</nav>
