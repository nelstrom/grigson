<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{{ title }} — grigson</title>
    <style>
      :root {
        color-scheme: light dark;
        --color-bg: #ffffff;
        --color-fg: #1a1a1a;
        --color-border: #cccccc;
        --color-border-subtle: #dddddd;
        --color-error: #cc0000;
        --color-editor-bg: #fafafa;
        --color-link: #0062cc;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #1e1e1e;
          --color-fg: #d4d4d4;
          --color-border: #444444;
          --color-border-subtle: #333333;
          --color-error: #f47272;
          --color-editor-bg: #1e1e1e;
          --color-link: #6ab0f5;
        }
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-fg);
        margin: 0;
        padding: 1rem 2rem;
        font-family: system-ui, sans-serif;
        line-height: 1.6;
      }

      a {
        color: var(--color-link);
      }

      nav {
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        flex-wrap: wrap;
      }

      nav .nav-primary {
        display: flex;
        align-items: baseline;
        gap: 0.4rem;
        flex-wrap: wrap;
        flex: 1;
      }

      nav .nav-api {
        font-size: 0.8rem;
        opacity: 0.7;
      }

      nav .nav-api:hover {
        opacity: 1;
      }

      pre, code {
        background: color-mix(in srgb, var(--color-fg) 8%, var(--color-bg));
        border-radius: 3px;
      }

      pre {
        padding: 0.75rem 1rem;
        overflow-x: auto;
      }

      code {
        padding: 0.1em 0.3em;
      }

      pre code {
        background: none;
        padding: 0;
      }

      @media (prefers-color-scheme: dark) {
        .shiki, .shiki span {
          color: var(--shiki-dark) !important;
          background-color: var(--shiki-dark-bg) !important;
        }
      }
    </style>
    {% block scripts %}
    <script defer src="{{ '/js/grigson.iife.js' | url }}"></script>
    <script defer src="{{ '/js/grigson-register.iife.js' | url }}"></script>
    {% endblock %}
  </head>
  <body>
    <nav>
      <div class="nav-primary">
        <a href="{{ '/' | url }}">grigson</a>
        |
        <a href="{{ '/language/' | url }}">Language</a>
        |
        <a href="{{ '/renderers/' | url }}">Renderers</a>
        |
        <a href="{{ '/accessibility/' | url }}">Accessibility</a>
        |
        <a href="{{ '/cli/' | url }}">CLI</a>
        |
        <a href="{{ '/tutorial/' | url }}">Tutorial</a>
        |
        <a href="{{ '/songbook/' | url }}">Songbook</a>
        |
        <a href="{{ '/playground/' | url }}">Playground</a>
        |
        <a href="{{ '/ast-explorer/' | url }}">AST Explorer</a>
      </div>
      <a class="nav-api" href="{{ '/api/' | url }}">API Reference</a>
    </nav>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>grigson — a .chart file parser and normaliser</p>
    </footer>
  </body>
</html>
