<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{{ title }} — grigson</title>
    <style>
      :root {
        color-scheme: light dark;
        --color-bg: #ffffff;
        --color-fg: #1a1a1a;
        --color-border: #cccccc;
        --color-border-subtle: #dddddd;
        --color-error: #cc0000;
        --color-editor-bg: #fafafa;
        --color-link: #0062cc;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --color-bg: #1e1e1e;
          --color-fg: #d4d4d4;
          --color-border: #444444;
          --color-border-subtle: #333333;
          --color-error: #f47272;
          --color-editor-bg: #1e1e1e;
          --color-link: #6ab0f5;
        }
      }

      body {
        background-color: var(--color-bg);
        color: var(--color-fg);
        margin: 0;
        padding: 1rem 2rem;
        font-family: system-ui, sans-serif;
        line-height: 1.6;
      }

      a {
        color: var(--color-link);
      }

      nav {
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
      }

      pre, code {
        background: color-mix(in srgb, var(--color-fg) 8%, var(--color-bg));
        border-radius: 3px;
      }

      pre {
        padding: 0.75rem 1rem;
        overflow-x: auto;
      }

      code {
        padding: 0.1em 0.3em;
      }

      pre code {
        background: none;
        padding: 0;
      }
    </style>
    <script src="/js/grigson.iife.js"></script>
    <script src="/js/grigson-register.iife.js"></script>
  </head>
  <body>
    <nav>
      <a href="/">grigson</a>
      |
      <a href="/format/">Chart Format</a>
      |
      <a href="/cli/">CLI Reference</a>
      |
      <a href="/renderer/">Renderer</a>
      |
      <a href="/testing/">Testing</a>
      |
      <a href="/demo/">Demo</a>
      |
      <a href="/elements/">Custom Elements</a>
      |
      <a href="/playground/">Playground</a>
      |
      <a href="/tutorial/">Tutorial</a>
      |
      <a href="/songbook/">Songbook</a>
    </nav>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>grigson — a .chart file parser and normaliser</p>
    </footer>
  </body>
</html>
