  </figure>

  <figure class="subdivision-demo">
    <div class="cg-row">
      <div class="cg-bar bar-2">
        <div class="zone zone-tl"></div>
        <div class="zone zone-br"></div>
        <span class="chord chord-tl">Dm<sup>7♭5</sup></span>
        <span class="chord chord-br">G<sup>7</sup></span>
      </div>
    </div>
    <figcaption>2 chords — half bar each</figcaption>
  </figure>

  <figure class="subdivision-demo">
    <div class="cg-row">
      <div class="cg-bar bar-4">
        <div class="zone zone-top"></div>
        <div class="zone zone-right"></div>
        <div class="zone zone-bottom"></div>
        <div class="zone zone-left"></div>
        <span class="chord chord-top">Cm<sup>7</sup></span>
        <span class="chord chord-right">B♭<sup>7</sup></span>
        <span class="chord chord-bottom">A♭<sup>△</sup></span>
        <span class="chord chord-left">G<sup>7</sup></span>
      </div>
    </div>
    <figcaption>4 chords — one beat each</figcaption>
  </figure>
</div>

