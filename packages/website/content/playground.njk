<h1>Playground</h1>

<p>Type or paste a chord chart below. <code>grigson</code> will live-normalise it for you.</p>

<style>
  #playground-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: calc(100vh - 300px);
    min-height: 400px;
  }
  #input-editor {
    flex: 1;
    border: 1px solid #ccc;
  }
  #output-container {
    flex: 1;
    overflow: auto;
    border: 1px solid #ddd;
    margin: 0;
    position: relative;
    background: #fff;
  }
  #output-container pre {
    margin: 0;
    padding: 1rem;
    height: 100%;
    box-sizing: border-box;
  }
  .error {
    color: #cc0000;
    padding: 1rem;
    white-space: pre-wrap;
    background: #fff;
  }
</style>

<div id="playground-container">
  <div id="input-editor"></div>

  <div id="output-container"></div>
</div>

<script src="/js/monaco/vs/loader.js"></script>
<script type="module">
  import { createHighlighter } from 'https://esm.sh/shiki@4.0.2';

  require.config({ paths: { 'vs': '/js/monaco/vs' } });

  require(['vs/editor/editor.main'], async function() {
    const outputContainer = document.getElementById('output-container');
    const renderer = new grigson.TextRenderer();

    let highlighter;
    try {
      const response = await fetch('/js/grigson.tmLanguage.json');
      const grammar = await response.json();

      highlighter = await createHighlighter({
        themes: ['nord'],
        langs: [{
          ...grammar,
          name: 'grigson'
        }]
      });
    } catch (e) {
      console.error('Failed to load Shiki or grammar:', e);
      outputContainer.innerHTML = '<div class="error">Failed to load syntax highlighter</div>';
    }

    const editor = monaco.editor.create(document.getElementById('input-editor'), {
      value: '---\ntitle: Playground Example\nkey: F\n---\n| F | A# | F | C7 |\n|F|Bb|C|F|\n',
      language: 'plaintext', // We will add grigson language in the next task
      theme: 'vs-light',
      minimap: { enabled: false },
      automaticLayout: true,
      fontSize: 14,
      fontFamily: 'monospace',
    });

    function update() {
      try {
        const value = editor.getValue();
        const song = grigson.parseSong(value);
        const normalised = grigson.normaliseSong(song);
        const text = renderer.render(normalised);

        if (highlighter) {
          outputContainer.innerHTML = highlighter.codeToHtml(text, {
            lang: 'grigson',
            theme: 'nord'
          });
        } else {
          outputContainer.innerHTML = `<pre>${text}</pre>`;
        }
      } catch (e) {
        outputContainer.innerHTML = `<div class="error">Error: ${e.message}</div>`;
      }
    }

    editor.onDidChangeModelContent(update);
    update();
  });
</script>
