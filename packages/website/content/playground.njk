<h1>Playground</h1>

<p>Type or paste a chord chart below. <code>grigson</code> will live-normalise it for you.</p>

<style>
  #playground-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  #editor-section {
    display: flex;
    flex-direction: column;
    height: 400px;
  }
  #editor-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0;
    flex-shrink: 0;
  }
  #format-btn {
    font-size: 0.85rem;
    padding: 0.2rem 0.6rem;
    cursor: pointer;
  }
  #format-error {
    color: var(--color-error);
    font-size: 0.85em;
  }
  #input-editor {
    flex: 1;
    border: 1px solid var(--color-border);
    min-height: 0;
  }
  #output-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  #renderer-toolbar {
    display: grid;
    grid-template-columns: max-content 1fr;
    align-items: center;
    column-gap: 0.5rem;
    row-gap: 0.35rem;
    font-size: 0.85rem;
  }
  #html-options {
    display: contents;
  }
  #html-options[hidden] {
    display: none !important;
  }
  #output-container {
    border: 1px solid var(--color-border-subtle);
    background: var(--color-bg);
  }
  #output-container pre {
    margin: 0;
    padding: 1rem;
  }
  .error {
    color: var(--color-error);
    padding: 1rem;
    white-space: pre-wrap;
    background: var(--color-bg);
  }
  @media (min-width: 800px) {
    #playground-container {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
    }
    #editor-section {
      flex: 1;
      position: sticky;
      top: 1rem;
      height: calc(100vh - 2rem);
    }
    #output-section {
      flex: 1;
      min-width: 0;
    }
  }
</style>

<div id="playground-container">
  <div id="editor-section">
    <div id="editor-toolbar">
      <button id="format-btn" type="button">Format</button>
      <span id="format-error" hidden></span>
    </div>
    <div id="input-editor"></div>
  </div>

  <div id="output-section">
    <div id="renderer-toolbar">
    <label for="transpose-select">Transpose:</label>
    <select id="transpose-select">
      <option value="11">Up 11 semitones</option>
      <option value="10">Up 10 semitones</option>
      <option value="9">Up 9 semitones</option>
      <option value="8">Up 8 semitones</option>
      <option value="7">Up 7 semitones</option>
      <option value="6">Up 6 semitones</option>
      <option value="5">Up 5 semitones</option>
      <option value="4">Up 4 semitones</option>
      <option value="3">Up 3 semitones</option>
      <option value="2">Up 2 semitones</option>
      <option value="1">Up 1 semitone</option>
      <option value="0" selected>None (default)</option>
      <option value="-1">Down 1 semitone</option>
      <option value="-2">Down 2 semitones</option>
      <option value="-3">Down 3 semitones</option>
      <option value="-4">Down 4 semitones</option>
      <option value="-5">Down 5 semitones</option>
      <option value="-6">Down 6 semitones</option>
      <option value="-7">Down 7 semitones</option>
      <option value="-8">Down 8 semitones</option>
      <option value="-9">Down 9 semitones</option>
      <option value="-10">Down 10 semitones</option>
      <option value="-11">Down 11 semitones</option>
    </select>
    <label for="renderer-select">Renderer:</label>
    <select id="renderer-select">
      <option value="html">HTML</option>
      <option value="text">Text</option>
    </select>
    <span id="html-options">
      <label for="line-length-select">Line length:</label>
      <select id="line-length-select">
        <option value="">Auto (default)</option>
        <optgroup label="Max bars per line">
          <option value="max:2">Max 2</option>
          <option value="max:3">Max 3</option>
          <option value="max:4">Max 4</option>
          <option value="max:5">Max 5</option>
          <option value="max:6">Max 6</option>
          <option value="max:7">Max 7</option>
          <option value="max:8">Max 8</option>
          <option value="max:9">Max 9</option>
          <option value="max:10">Max 10</option>
          <option value="max:11">Max 11</option>
          <option value="max:12">Max 12</option>
        </optgroup>
        <optgroup label="Fixed bars per line">
          <option value="fixed:2">Fixed 2</option>
          <option value="fixed:3">Fixed 3</option>
          <option value="fixed:4">Fixed 4</option>
          <option value="fixed:5">Fixed 5</option>
          <option value="fixed:6">Fixed 6</option>
          <option value="fixed:7">Fixed 7</option>
          <option value="fixed:8">Fixed 8</option>
          <option value="fixed:9">Fixed 9</option>
          <option value="fixed:10">Fixed 10</option>
          <option value="fixed:11">Fixed 11</option>
          <option value="fixed:12">Fixed 12</option>
        </optgroup>
      </select>
      <label for="typeface-select">Typeface:</label>
      <select id="typeface-select">
        <option value="sans">Sans-serif (default)</option>
        <option value="serif">Serif</option>
        <option value="cursive">Cursive (Petaluma)</option>
      </select>
      <label for="notation-preset-select">Notation preset:</label>
      <select id="notation-preset-select">
        <option value="">Default</option>
        <option value="realbook">Real Book</option>
      </select>
      <label for="simile-output-select">Simile:</label>
      <select id="simile-output-select">
        <option value="">Longhand (default)</option>
        <option value="shorthand">Shorthand</option>
      </select>
      <label for="accidentals-select">Accidentals:</label>
      <select id="accidentals-select">
        <option value="">Unicode ♭♯ (default)</option>
        <option value="ascii">ASCII b#</option>
      </select>
      <label for="slash-style-select">Slash chords:</label>
      <select id="slash-style-select">
        <option value="">Diagonal (default)</option>
        <option value="horizontal">Horizontal</option>
        <option value="ascii">ASCII /</option>
      </select>
    </span>
    </div>

    <div id="output-container">
      <grigson-chart id="playground-output" normalise></grigson-chart>
    </div>
  </div>
</div>

<script src="{{ '/js/grigson-text-renderer-register.iife.js' | url }}"></script>
<script src="{{ '/js/lz-string.min.js' | url }}"></script>
<script src="{{ '/assets/js/grigson-monarch.js' | url }}"></script>
<script src="{{ '/js/monaco/vs/loader.js' | url }}"></script>
<script type="module">
  import { z } from 'https://esm.sh/zod';

  const rendererConfigSchema = z.discriminatedUnion('name', [
    z.object({
      name: z.literal('html'),
      typeface: z.enum(['sans', 'serif', 'cursive']).optional(),
      preset: z.string().optional(),
      simileOutput: z.enum(['shorthand', 'longhand']).optional(),
      accidentals: z.enum(['ascii', 'unicode']).optional(),
      slashStyle: z.enum(['horizontal', 'diagonal', 'ascii']).optional(),
      barsPerLine: z.number().int().min(1).optional(),
      maxBarsPerLine: z.number().int().min(1).optional(),
      transposeSemitones: z.number().int().min(-11).max(11).optional(),
    }),
    z.object({
      name: z.literal('text'),
      transposeSemitones: z.number().int().min(-11).max(11).optional(),
    }),
  ]);

  // lz-string.min.js is loaded as a plain script before Monaco's AMD loader,
  // so it initialises as window.LZString without AMD interference.
  const { compressToEncodedURIComponent, decompressFromEncodedURIComponent } = LZString;

  require.config({ paths: { 'vs': '{{ '/js/monaco/vs' | url }}' } });

  require(['vs/editor/editor.main'], function () {
    const DEFAULT_VALUE = `---
title: "Demo chart"
key: F# major
meter: 4/4
---

# This is a comment line
| F# | B | C#7 | D#m |
| G#m | C#7 | F# | Bm7b5 |
| A Bb | C7 Dm | Em7b5 F | G Am G7 . |
| Cmaj7  | Bdim7 Am7 | Fmaj7 | Cmaj7 |
| G7b5 | F#7b5 | Cm7 | Bbm7 |
||: C | F :||: G | C :||
| F/C | Am/E | Cm7/Bb | G/B ||.
`;

    function readHash() {
      const hash = location.hash;
      if (hash.startsWith('#code/')) {
        const encoded = hash.slice('#code/'.length);
        return decompressFromEncodedURIComponent(encoded) ?? DEFAULT_VALUE;
      }
      return DEFAULT_VALUE;
    }

    function readRendererConfig() {
      const params = new URLSearchParams(location.search);
      const raw = params.get('renderer-config');
      if (!raw) return { name: 'html' };
      try {
        return rendererConfigSchema.parse(JSON.parse(raw));
      } catch {
        return { name: 'html' };
      }
    }

    const outputElement = document.getElementById('playground-output');
    const rendererSelect = document.getElementById('renderer-select');
    const transposeSelect = document.getElementById('transpose-select');
    const typefaceSelect = document.getElementById('typeface-select');
    const notationPresetSelect = document.getElementById('notation-preset-select');
    const simileOutputSelect = document.getElementById('simile-output-select');
    const accidentalsSelect = document.getElementById('accidentals-select');
    const slashStyleSelect = document.getElementById('slash-style-select');
    const lineLengthSelect = document.getElementById('line-length-select');
    const htmlOptions = document.getElementById('html-options');

    function applyLineLength(renderer) {
      const val = lineLengthSelect.value;
      renderer.removeAttribute('bars-per-line');
      renderer.removeAttribute('max-bars-per-line');
      if (!val) return;
      const [mode, n] = val.split(':');
      if (mode === 'fixed') renderer.setAttribute('bars-per-line', n);
      else if (mode === 'max') renderer.setAttribute('max-bars-per-line', n);
    }

    let currentRenderer = null;

    function applyRenderer() {
      if (currentRenderer && currentRenderer.parentNode === outputElement) {
        outputElement.removeChild(currentRenderer);
      }

      const name = rendererSelect.value;
      if (name === 'text') {
        currentRenderer = document.createElement('grigson-text-renderer');
        htmlOptions.hidden = true;
      } else {
        currentRenderer = document.createElement('grigson-html-renderer');
        currentRenderer.setAttribute('typeface', typefaceSelect.value);
        const preset = notationPresetSelect.value;
        if (preset) currentRenderer.setAttribute('notation-preset', preset);
        const simileOutput = simileOutputSelect.value;
        if (simileOutput) currentRenderer.setAttribute('simile-output', simileOutput);
        const accidentals = accidentalsSelect.value;
        if (accidentals) currentRenderer.setAttribute('accidentals', accidentals);
        const slashStyle = slashStyleSelect.value;
        if (slashStyle) currentRenderer.setAttribute('slash-style', slashStyle);
        applyLineLength(currentRenderer);
        htmlOptions.hidden = false;
      }

      const template = outputElement.querySelector('template');
      outputElement.insertBefore(currentRenderer, template ?? null);
    }

    // Register language and define Monarch tokenizer.
    // (Monaco's Monarch is built into the AMD bundle — no external oniguruma needed.)
    monaco.languages.register({ id: 'grigson' });

    monaco.languages.setMonarchTokensProvider('grigson', window.grigsonMonarchTokens);

    // Define light and dark themes
    monaco.editor.defineTheme('grigson-light', {
      base: 'vs',
      inherit: true,
      rules: [
        { token: 'punctuation.definition.header.grigson', foreground: 'A0A1A7' },
        { token: 'variable.parameter.key.grigson', foreground: 'E45649', fontStyle: 'bold' },
        { token: 'punctuation.separator.key-value.grigson', foreground: '404040' },
        { token: 'string.quoted.double.grigson', foreground: '50A14F' },
        { token: 'string.unquoted.grigson', foreground: '50A14F' },
        { token: 'punctuation.definition.barline.grigson', foreground: 'A0A1A7', fontStyle: 'bold' },
        { token: 'constant.other.chord.root.grigson', foreground: '4078F2', fontStyle: 'bold' },
        { token: 'constant.other.chord.accidental.grigson', foreground: '4078F2' },
        { token: 'keyword.other.chord.quality.grigson', foreground: '986801' },
      ],
      colors: { 'editor.background': '#FAFAFA' },
    });

    monaco.editor.defineTheme('grigson-dark', {
      base: 'vs-dark',
      inherit: true,
      rules: [
        { token: 'punctuation.definition.header.grigson', foreground: '6A737D' },
        { token: 'variable.parameter.key.grigson', foreground: 'F97583', fontStyle: 'bold' },
        { token: 'punctuation.separator.key-value.grigson', foreground: '9ECBFF' },
        { token: 'string.quoted.double.grigson', foreground: '85E89D' },
        { token: 'string.unquoted.grigson', foreground: '85E89D' },
        { token: 'punctuation.definition.barline.grigson', foreground: '6A737D', fontStyle: 'bold' },
        { token: 'constant.other.chord.root.grigson', foreground: '79B8FF', fontStyle: 'bold' },
        { token: 'constant.other.chord.accidental.grigson', foreground: '79B8FF' },
        { token: 'keyword.other.chord.quality.grigson', foreground: 'FFAB70' },
      ],
      colors: { 'editor.background': '#1E1E1E' },
    });

    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
    const getTheme = () => prefersDark.matches ? 'grigson-dark' : 'grigson-light';

    const editor = monaco.editor.create(document.getElementById('input-editor'), {
      value: readHash(),
      language: 'grigson',
      theme: getTheme(),
      minimap: { enabled: false },
      automaticLayout: true,
      fontSize: 14,
      fontFamily: 'monospace',
    });

    prefersDark.addEventListener('change', () => {
      monaco.editor.setTheme(getTheme());
    });

    let urlTimer;
    function updateURL() {
      clearTimeout(urlTimer);
      urlTimer = setTimeout(() => {
        const config = { name: rendererSelect.value };
        if (rendererSelect.value === 'html') {
          if (typefaceSelect.value !== 'sans') config.typeface = typefaceSelect.value;
          if (notationPresetSelect.value) config.preset = notationPresetSelect.value;
          if (simileOutputSelect.value) config.simileOutput = simileOutputSelect.value;
          if (accidentalsSelect.value) config.accidentals = accidentalsSelect.value;
          if (slashStyleSelect.value) config.slashStyle = slashStyleSelect.value;
          const llVal = lineLengthSelect.value;
          if (llVal) {
            const [mode, n] = llVal.split(':');
            if (mode === 'fixed') config.barsPerLine = parseInt(n, 10);
            else if (mode === 'max') config.maxBarsPerLine = parseInt(n, 10);
          }
        }
        const semitones = parseInt(transposeSelect.value, 10);
        if (semitones !== 0) config.transposeSemitones = semitones;
        const params = new URLSearchParams();
        if (config.name !== 'html' || config.typeface || config.preset || config.simileOutput || config.accidentals || config.slashStyle || config.barsPerLine || config.maxBarsPerLine || config.transposeSemitones) {
          params.set('renderer-config', JSON.stringify(config));
        }
        const compressed = compressToEncodedURIComponent(editor.getValue());
        const query = params.toString() ? '?' + params.toString() : '';
        history.replaceState(null, '', query + '#code/' + compressed);
      }, 500);
    }

    function update() {
      updateURL();
      const value = editor.getValue();
      let template = outputElement.querySelector('template');
      if (!template) {
        template = document.createElement('template');
        outputElement.appendChild(template);
      }
      template.innerHTML = value;
      outputElement.update();

      const diagnostics = grigson.validate(value);
      monaco.editor.setModelMarkers(editor.getModel(), 'grigson', diagnostics.map(d => ({
        startLineNumber: d.range.start.line + 1,
        startColumn:     d.range.start.character + 1,
        endLineNumber:   d.range.end.line + 1,
        endColumn:       d.range.end.character + 1,
        severity:        d.severity === 'error'
                           ? monaco.MarkerSeverity.Error
                           : monaco.MarkerSeverity.Warning,
        message:         d.message,
      })));
    }

    // Initialize renderer selects from URL and apply the renderer
    const initialConfig = readRendererConfig();
    rendererSelect.value = initialConfig.name;
    transposeSelect.value = String(initialConfig.transposeSemitones ?? 0);
    typefaceSelect.value = initialConfig.typeface ?? 'sans';
    notationPresetSelect.value = initialConfig.preset ?? '';
    simileOutputSelect.value = initialConfig.simileOutput ?? '';
    accidentalsSelect.value = initialConfig.accidentals ?? '';
    slashStyleSelect.value = initialConfig.slashStyle ?? '';
    if (initialConfig.barsPerLine) lineLengthSelect.value = `fixed:${initialConfig.barsPerLine}`;
    else if (initialConfig.maxBarsPerLine) lineLengthSelect.value = `max:${initialConfig.maxBarsPerLine}`;
    else lineLengthSelect.value = '';
    const initialSemitones = initialConfig.transposeSemitones ?? 0;
    if (initialSemitones !== 0) outputElement.setAttribute('transpose-semitones', String(initialSemitones));
    applyRenderer();

    editor.onDidChangeModelContent(update);
    update();

    rendererSelect.addEventListener('change', () => {
      applyRenderer();
      outputElement.update();
      updateURL();
    });

    transposeSelect.addEventListener('change', () => {
      const semitones = parseInt(transposeSelect.value, 10);
      if (semitones !== 0) outputElement.setAttribute('transpose-semitones', String(semitones));
      else outputElement.removeAttribute('transpose-semitones');
      outputElement.update();
      updateURL();
    });

    typefaceSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        currentRenderer.setAttribute('typeface', typefaceSelect.value);
        outputElement.update();
      }
      updateURL();
    });

    notationPresetSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        const preset = notationPresetSelect.value;
        if (preset) currentRenderer.setAttribute('notation-preset', preset);
        else currentRenderer.removeAttribute('notation-preset');
        outputElement.update();
      }
      updateURL();
    });

    simileOutputSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        const simileOutput = simileOutputSelect.value;
        if (simileOutput) currentRenderer.setAttribute('simile-output', simileOutput);
        else currentRenderer.removeAttribute('simile-output');
        outputElement.update();
      }
      updateURL();
    });

    accidentalsSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        const accidentals = accidentalsSelect.value;
        if (accidentals) currentRenderer.setAttribute('accidentals', accidentals);
        else currentRenderer.removeAttribute('accidentals');
        outputElement.update();
      }
      updateURL();
    });

    slashStyleSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        const slashStyle = slashStyleSelect.value;
        if (slashStyle) currentRenderer.setAttribute('slash-style', slashStyle);
        else currentRenderer.removeAttribute('slash-style');
        outputElement.update();
      }
      updateURL();
    });

    lineLengthSelect.addEventListener('change', () => {
      if (currentRenderer && rendererSelect.value === 'html') {
        applyLineLength(currentRenderer);
        outputElement.update();
      }
      updateURL();
    });

    const formatBtn = document.getElementById('format-btn');
    const formatError = document.getElementById('format-error');

    formatBtn.addEventListener('click', () => {
      const value = editor.getValue();
      try {
        const song = grigson.parseSong(value);
        const normalised = grigson.normaliseSong(song);
        const formatted = new grigson.TextRenderer().render(normalised);
        const model = editor.getModel();
        editor.executeEdits('format', [{ range: model.getFullModelRange(), text: formatted }]);
        editor.focus();
        formatError.textContent = '';
        formatError.hidden = true;
      } catch (err) {
        formatError.textContent = err.message;
        formatError.hidden = false;
      }
    });
  });
</script>
