<h1>Playground</h1>

<p>Type or paste a chord chart below. <code>grigson</code> will live-normalise it for you.</p>

<style>
  #playground-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: calc(100vh - 300px);
    min-height: 400px;
  }
  #input-editor {
    flex: 1;
    border: 1px solid #ccc;
  }
  #output-container {
    flex: 1;
    overflow: auto;
    border: 1px solid #ddd;
    margin: 0;
    position: relative;
    background: #fff;
  }
  #output-container pre {
    margin: 0;
    padding: 1rem;
    height: 100%;
    box-sizing: border-box;
  }
  .error {
    color: #cc0000;
    padding: 1rem;
    white-space: pre-wrap;
    background: #fff;
  }
</style>

<div id="playground-container">
  <div id="input-editor"></div>

  <div id="output-container">
    <grigson-chart id="playground-output" normalise></grigson-chart>
  </div>
</div>

<script src="/js/monaco/vs/loader.js"></script>
<script type="module">
  import { loadWASM, createOnigScanner, createOnigString } from 'https://esm.sh/vscode-oniguruma@2.0.1';
  import { Registry, INITIAL } from 'https://esm.sh/monaco-textmate@3.0.1';

  require.config({ paths: { 'vs': '/js/monaco/vs' } });

  require(['vs/editor/editor.main'], async function() {
    const outputElement = document.getElementById('playground-output');

    // 1. Initialize vscode-oniguruma
    try {
      const wasmResponse = await fetch('/js/onig.wasm');
      const wasmBinary = await wasmResponse.arrayBuffer();
      await loadWASM(wasmBinary);
    } catch (e) {
      console.error('Failed to initialize oniguruma:', e);
    }

    // 2. Load grammar
    let grammar;
    try {
      const response = await fetch('/js/grigson.tmLanguage.json');
      grammar = await response.json();
    } catch (e) {
      console.error('Failed to load grammar:', e);
      return;
    }

    // 3. Setup Monaco TextMate
    const registry = new Registry({
      getOnigLib: async () => ({
        createOnigScanner: (sources) => createOnigScanner(sources),
        createOnigString: (str) => createOnigString(str),
      }),
      getGrammarDefinition: async (scopeName) => {
        if (scopeName === 'source.grigson') {
          return {
            format: 'json',
            content: grammar
          };
        }
        return null;
      }
    });

    monaco.languages.register({ id: 'grigson' });
    const monacoGrammar = await registry.loadGrammar('source.grigson');

    monaco.languages.setTokensProvider('grigson', {
      getInitialState: () => INITIAL,
      tokenize: (line, state) => {
        const result = monacoGrammar.tokenizeLine(line, state);
        return {
          tokens: result.tokens.map(token => ({
            startIndex: token.startIndex,
            scopes: token.scopes[token.scopes.length - 1]
          })),
          endState: result.ruleStack
        };
      }
    });

    // 4. Define theme
    monaco.editor.defineTheme('grigson-theme', {
      base: 'vs-light',
      inherit: true,
      rules: [
        { token: 'punctuation.definition.header.grigson', foreground: 'A0A1A7' },
        { token: 'variable.parameter.key.grigson', foreground: 'E45649', fontStyle: 'bold' },
        { token: 'punctuation.separator.key-value.grigson', foreground: '404040' },
        { token: 'string.quoted.double.grigson', foreground: '50A14F' },
        { token: 'string.unquoted.grigson', foreground: '50A14F' },
        { token: 'punctuation.definition.barline.grigson', foreground: 'A0A1A7', fontStyle: 'bold' },
        { token: 'constant.other.chord.root.grigson', foreground: '4078F2', fontStyle: 'bold' },
        { token: 'constant.other.chord.accidental.grigson', foreground: '4078F2' },
        { token: 'keyword.other.chord.quality.grigson', foreground: '986801' },
      ],
      colors: {
        'editor.background': '#FAFAFA',
      }
    });

    const editor = monaco.editor.create(document.getElementById('input-editor'), {
      value: '---\ntitle: Playground Example\nkey: F\n---\n| F | A# | F | C7 |\n|F|Bb|C|F|\n',
      language: 'grigson',
      theme: 'grigson-theme',
      minimap: { enabled: false },
      automaticLayout: true,
      fontSize: 14,
      fontFamily: 'monospace',
    });

    function update() {
      const value = editor.getValue();
      let template = outputElement.querySelector('template');
      if (!template) {
        template = document.createElement('template');
        outputElement.appendChild(template);
      }
      template.innerHTML = value;
      outputElement.update();
    }

    editor.onDidChangeModelContent(update);
    update();
  });
</script>
