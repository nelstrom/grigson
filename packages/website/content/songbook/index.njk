title: Songbook
permalink: /songbook/
---
<h1>Songbook</h1>
<p>Reference charts used to verify the HTML renderer.</p>
<ol>
  {% for song in collections.songbook | sort(false, false, 'data.order') %}
    <li><a href="{{ song.url }}">{{ song.data.title }}</a>{% if song.data.artist %} <span class="song-artist">— {{ song.data.artist }}</span>{% endif %}</li>
  {% endfor %}
</ol>
