{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "grigson",
  "rules": {
    "song": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "frontmatter"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "comment"
              },
              {
                "type": "SYMBOL",
                "name": "section_label"
              },
              {
                "type": "SYMBOL",
                "name": "row"
              },
              {
                "type": "PATTERN",
                "value": "\\r?\\n"
              }
            ]
          }
        }
      ]
    },
    "comment": {
      "type": "PATTERN",
      "value": "#[^\\r\\n]*"
    },
    "section_label": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "SYMBOL",
          "name": "section_name"
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "section_name": {
      "type": "PATTERN",
      "value": "[^\\]\\r\\n]+"
    },
    "frontmatter": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "frontmatter_delimiter"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "frontmatter_field"
          }
        },
        {
          "type": "SYMBOL",
          "name": "frontmatter_delimiter"
        }
      ]
    },
    "frontmatter_delimiter": {
      "type": "PATTERN",
      "value": "---[ \\t]*\\r?\\n"
    },
    "frontmatter_field": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "frontmatter_key"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "frontmatter_value"
        },
        {
          "type": "PATTERN",
          "value": "\\r?\\n"
        }
      ]
    },
    "frontmatter_key": {
      "type": "PATTERN",
      "value": "[a-zA-Z]+"
    },
    "frontmatter_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "quoted_string"
        },
        {
          "type": "SYMBOL",
          "name": "unquoted_value"
        }
      ]
    },
    "quoted_string": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "unquoted_value": {
      "type": "PATTERN",
      "value": "[^\\r\\n\\t \"][^\\r\\n]*"
    },
    "row": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "open_barline"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "bar_tail"
          }
        }
      ]
    },
    "bar_tail": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "time_signature"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "REPEAT1",
              "content": {
                "type": "SYMBOL",
                "name": "beat_slot"
              }
            },
            {
              "type": "SYMBOL",
              "name": "close_barline"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "simile_mark"
            },
            {
              "type": "SYMBOL",
              "name": "close_barline"
            }
          ]
        }
      ]
    },
    "simile_mark": {
      "type": "STRING",
      "value": "%"
    },
    "beat_slot": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "chord"
        },
        {
          "type": "SYMBOL",
          "name": "dot"
        }
      ]
    },
    "dot": {
      "type": "STRING",
      "value": "."
    },
    "open_barline": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": ":||:"
          },
          {
            "type": "STRING",
            "value": ":||"
          },
          {
            "type": "STRING",
            "value": "||:"
          },
          {
            "type": "STRING",
            "value": "||"
          },
          {
            "type": "STRING",
            "value": "|"
          }
        ]
      }
    },
    "close_barline": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": ":\\|\\|x\\d+:"
          },
          {
            "type": "PATTERN",
            "value": ":\\|\\|x\\d+"
          },
          {
            "type": "STRING",
            "value": ":||:"
          },
          {
            "type": "STRING",
            "value": ":||"
          },
          {
            "type": "STRING",
            "value": "||:"
          },
          {
            "type": "STRING",
            "value": "||."
          },
          {
            "type": "STRING",
            "value": "||"
          },
          {
            "type": "STRING",
            "value": "|"
          }
        ]
      }
    },
    "time_signature": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "SYMBOL",
          "name": "integer"
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "integer": {
      "type": "PATTERN",
      "value": "[0-9]+"
    },
    "chord": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "note_letter"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "accidental"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "quality"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "slash_bass"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "slash_bass": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "SYMBOL",
          "name": "note_letter"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "accidental"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "note_letter": {
      "type": "PATTERN",
      "value": "[A-G]"
    },
    "accidental": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[#b]"
      }
    },
    "quality": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "m7b5"
          },
          {
            "type": "STRING",
            "value": "maj7"
          },
          {
            "type": "STRING",
            "value": "M7"
          },
          {
            "type": "STRING",
            "value": "dim7"
          },
          {
            "type": "STRING",
            "value": "m7"
          },
          {
            "type": "STRING",
            "value": "dim"
          },
          {
            "type": "STRING",
            "value": "m"
          },
          {
            "type": "STRING",
            "value": "7b13"
          },
          {
            "type": "STRING",
            "value": "7b9"
          },
          {
            "type": "STRING",
            "value": "7#9"
          },
          {
            "type": "STRING",
            "value": "7#5"
          },
          {
            "type": "STRING",
            "value": "7b5"
          },
          {
            "type": "STRING",
            "value": "7"
          },
          {
            "type": "STRING",
            "value": "sus4"
          },
          {
            "type": "STRING",
            "value": "sus2"
          },
          {
            "type": "STRING",
            "value": "13"
          },
          {
            "type": "STRING",
            "value": "11"
          },
          {
            "type": "STRING",
            "value": "9"
          },
          {
            "type": "STRING",
            "value": "6"
          },
          {
            "type": "STRING",
            "value": "-"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
