{
  "name": "tree-sitter-grigson",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Grigson chord chart format",
  "main": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate && oxfmt --config ../../.oxfmtrc.json src/grammar.json src/node-types.json",
    "build": "tree-sitter generate && oxfmt --config ../../.oxfmtrc.json src/grammar.json src/node-types.json",
    "test": "tree-sitter test"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.0"
  },
  "tree-sitter": [
    {
      "scope": "source.grigson",
      "file-types": [
        "chart"
      ]
    }
  ]
}
