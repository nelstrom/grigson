---
layout: base.njk
title: Font Explorer
---

<h1>Grigson Font Explorer</h1>

<h2>Source fonts</h2>
<ul>
  {% for font in fontPages %}
    {% if not font.derived %}
      <li><a href="/{{ font.slug }}/">{{ font.name }}</a> — {{ font.totalGlyphs }} glyphs ({{ font.outline }}, {{ font.upm }} UPM)</li>
    {% endif %}
  {% endfor %}
</ul>

<h2>Derived fonts</h2>
<ul>
  {% for font in fontPages %}
    {% if font.derived %}
      <li><a href="/{{ font.slug }}/">{{ font.name }}</a> — {{ font.totalGlyphs }} glyphs ({{ font.outline }}, {{ font.upm }} UPM)</li>
    {% endif %}
  {% endfor %}
</ul>
