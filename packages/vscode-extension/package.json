{
  "name": "vscode-grigson",
  "displayName": "Grigson Chord Charts",
  "description": "Syntax highlighting and tools for Grigson .chart files",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:grigson"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "grigson",
        "aliases": [
          "Grigson",
          "grigson"
        ],
        "extensions": [
          ".chart"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "grigson",
        "scopeName": "source.grigson",
        "path": "./syntaxes/grigson.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "grigson-language-server": "workspace:*",
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  }
}
