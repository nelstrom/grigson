{
  "allowedTools": [
    "Bash(pnpm run *)",
    "Bash(pnpm install*)",
    "Bash(pnpm add *)",
    "Bash(git status)",
    "Bash(git diff*)",
    "Bash(git log*)",
    "Bash(git add *)",
    "Bash(git commit*)"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-npm.sh"
          }
        ]
      }
    ]
  }
}
